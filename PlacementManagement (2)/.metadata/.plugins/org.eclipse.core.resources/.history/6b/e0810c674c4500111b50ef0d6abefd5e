	public String addJobSuggestion(JobSuggestionModel jobSuggestionModel, String name) {
		TutorModel tutorModel = tutorRepository.findByEmail(name).get(0);
		StudentModel studentModel  = studentRepository.findById(jobSuggestionModel.getStudentId()).get();
		JobPostModel jobPostModel = jobPostRepository.findById(jobSuggestionModel.getJobPostId()).get();
		jobSuggestionModel.setStudentModel(studentModel);
		jobSuggestionModel.setJobPostModel(jobPostModel);
		jobSuggestionModel.setStatus("PENDING");
		jobSuggestionModel.setTutorModel(tutorModel);
		jobSuggestionRepository.save(jobSuggestionModel);
		return "job-suggestion-posted.created";
	}


