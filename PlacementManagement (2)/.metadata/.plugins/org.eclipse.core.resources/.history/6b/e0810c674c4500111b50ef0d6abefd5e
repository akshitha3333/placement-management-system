	public String applyJob(long jobSuggestionId, JobApplicationModel jobApplicationModel) {
		jobApplicationModel.setAppliedOn(LocalDate.now());
		jobApplicationModel.setStatus(JobApplicationStatus.APPLIED);
		JobSuggestionModel jobSuggestionModel = jobSuggestionRepository.findById(jobSuggestionId).get();
		jobApplicationModel.setJobSuggestionModel(jobSuggestionModel);
		jobSuggestionModel.setStatus("APPLIED");
		jobSuggestionRepository.saveAndFlush(jobSuggestionModel);
		ResumeModel resumeModel = resumeRepository.findById(jobApplicationModel.getResumeId()).get();
		jobApplicationModel.setResumeModel(resumeModel);
		jobApplicationRepository.save(jobApplicationModel);
		return "job.application.submitted";
	}


