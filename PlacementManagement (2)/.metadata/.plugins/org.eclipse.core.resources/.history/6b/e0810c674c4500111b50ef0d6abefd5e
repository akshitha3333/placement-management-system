	public String acceptInterview(Long interviewId) {
		InterviewModel interviewModel = interviewRepository.findById(interviewId).get();
		interviewModel.setStatus(InterviewScheduleStatus.Accepted);
		interviewRepository.saveAndFlush(interviewModel);
		return "interview.accepted";
	}


	public String rejectInterview(Long interviewId) {
		InterviewModel interviewModel = interviewRepository.findById(interviewId).get();
		interviewModel.setStatus(InterviewScheduleStatus.Rejected_By_Student);
		interviewRepository.saveAndFlush(interviewModel);
		return "interview.rejected";
	}


	public String markAsSelected(Long interviewId) {
		InterviewModel interviewModel = interviewRepository.findById(interviewId).get();
		interviewModel.setStatus(InterviewScheduleStatus.Selected);
		JobApplicationModel jobApplicationModel = interviewModel.getJobApplicationModel();
		jobApplicationModel.setStatus(JobApplicationStatus.SELECTED);
		jobApplicationRepository.saveAndFlush(jobApplicationModel);
		interviewRepository.saveAndFlush(interviewModel);
		return "interview.student.selected";
	}


	public String notSelected(Long interviewId) {
		InterviewModel interviewModel = interviewRepository.findById(interviewId).get();
		interviewModel.setStatus(InterviewScheduleStatus.Rejected);
		JobApplicationModel jobApplicationModel = interviewModel.getJobApplicationModel();
		jobApplicationModel.setStatus(JobApplicationStatus.REJECTED);
		jobApplicationRepository.saveAndFlush(jobApplicationModel);
		interviewRepository.saveAndFlush(interviewModel);
		return "interview.student.rejected";
	}


	public String releaseOffer(Long interviewId, OfferLetterModel offerLetterModel) {
		InterviewModel interviewModel = interviewRepository.findById(interviewId).get();
		offerLetterModel.setInterviewModel(interviewModel);
		offerLetterRepository.save(offerLetterModel);
		interviewModel.setStatus(InterviewScheduleStatus.Offer_Sent);
		interviewRepository.saveAndFlush(interviewModel);
		return "offer-letter.released";
	}


