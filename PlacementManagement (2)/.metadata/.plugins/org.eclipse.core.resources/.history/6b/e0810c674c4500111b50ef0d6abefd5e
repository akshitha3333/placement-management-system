	 public String addJobPost(JobPostModel jobPostModel, List<Long> skillIds, String name) {
		    CompanyModel companyModel = companyRepository.findByEmail(name);
		    jobPostModel.setCompanyModel(companyModel);
	        JobPostModel savedJob = jobPostRepository.save(jobPostModel);
	        for (Long skillId : skillIds) {
	            SkillModel skill = skillRepository.findById(skillId).orElseThrow(() -> new RuntimeException("Skill not found with id: " + skillId));
	            JobPostSkillModel mapping = new JobPostSkillModel();
	            mapping.setJobPostModel(savedJob);
	            mapping.setSkillModel(skill);
	            jobPostSkillRepository.save(mapping);
	        }
	        return "SUCCESS";
	   }


