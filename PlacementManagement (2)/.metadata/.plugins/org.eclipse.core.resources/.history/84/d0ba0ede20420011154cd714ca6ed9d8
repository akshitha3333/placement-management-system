	@PostMapping(value = "/interview-schedule/offer-letter", consumes = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<?> releaseOffer(
            @RequestParam("offerLetter") MultipartFile file,
            @RequestParam long interviewId
            ) {

        try {
            String fileName = file.getOriginalFilename();
            File uploadedFile = new File(offferPath + File.separator + fileName);

            FileOutputStream fos = new FileOutputStream(uploadedFile);
            fos.write(file.getBytes());
            fos.close();

             OfferLetterModel offerLetterModel = new OfferLetterModel();
             offerLetterModel.setDate(LocalDate.now());
             offerLetterModel.setOfferLetter(file.getOriginalFilename());
            String response = jobService.releaseOffer(interviewId, offerLetterModel);

            if (response.equals("EXISTS")) {
                return ResponseEntity.status(HttpStatus.CONFLICT)
                        .body("Offer Already Exists");
            }
            return ResponseEntity.status(HttpStatus.CREATED)
                    .body("Offer Letter Released");

        } catch (Exception e) {
            e.printStackTrace();
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR)
                    .body("Error while Releasing offer");
        }
    }
	
