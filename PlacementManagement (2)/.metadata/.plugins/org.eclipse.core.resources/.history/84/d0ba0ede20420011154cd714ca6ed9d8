	@PostMapping(value = "/job-post", consumes = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<?> addJobPost(
            @RequestParam("poster") MultipartFile file,
            @RequestParam String title,
            @RequestParam String description,
            @RequestParam String requiredCandidate,
            @RequestParam String postedDate,
            @RequestParam String lastDateToApply,
            @RequestParam String eligiblePercentage,
            @RequestParam List<Long> skillIds,
            Principal principal) {

        try {
            String fileName = file.getOriginalFilename();
            File uploadedFile = new File(posterPath + File.separator + fileName);

            FileOutputStream fos = new FileOutputStream(uploadedFile);
            fos.write(file.getBytes());
            fos.close();

            JobPostModel job = new JobPostModel();
            job.setTiitle(title);
            job.setDescription(description);
            job.setRequiredCandidate(requiredCandidate);
            job.setPostedDate(postedDate);
            job.setLastDateToApply(lastDateToApply);
            job.setEligiblePercentage(eligiblePercentage);
            job.setPoster(fileName);

            // 🔹 Call service
            String response = jobService.addJobPost(job, skillIds,principal.getName());

            if (response.equals("EXISTS")) {
                return ResponseEntity.status(HttpStatus.CONFLICT)
                        .body("Job already exists");
            }
            return ResponseEntity.status(HttpStatus.CREATED)
                    .body("Job posted successfully");

        } catch (Exception e) {
            e.printStackTrace();
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR)
                    .body("Error while posting job");
        }
    }
	
	@GetMapping("/job-post")
	public ResponseEntity<ApiResponse<List<JobPostModel>>> getJobPosts(Principal principal){
		List<JobPostModel> jobPostModelsList = jobService.getJobPosts(principal.getName());
